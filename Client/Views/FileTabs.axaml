<!--
    FileTabs - Панель вкладок в стиле Windows 11.

    Layout: [ + ] [ ScrollViewer: Tabs... ] [ ← ] [ → ]

    Особенности:
    - Кнопка "+" зафиксирована слева (перед вкладками)
    - Вкладки прокручиваются в ScrollViewer
    - Стрелки появляются только при переполнении
    - Drag & drop для перемещения вкладок
    - Текст вкладок обрезается
    - Прокрутка колесиком мыши
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.ViewModels"
             xmlns:models="using:Client.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="36"
             x:Class="Client.Views.FileTabs"
             x:DataType="vm:FileTabsViewModel">

    <!-- СТИЛИ -->
    <UserControl.Styles>
        <!-- Кнопка вкладки -->
        <Style Selector="Button.tab-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="CornerRadius" Value="4,4,0,0"/>
        </Style>

        <!-- Активная вкладка -->
        <Style Selector="Button.tab-button.selected">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}"/>
        </Style>

        <!-- Hover -->
        <Style Selector="Button.tab-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
        </Style>

        <Style Selector="Button.tab-button.selected:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumHighBrush}"/>
        </Style>

        <!-- Кнопка закрытия вкладки -->
        <Style Selector="Button.close-tab-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.close-tab-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListMediumBrush}"/>
        </Style>

        <!-- Кнопка прокрутки (стрелка) -->
        <Style Selector="Button.scroll-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="CornerRadius" Value="2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.scroll-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
        </Style>

        <!-- Кнопка "+" -->
        <Style Selector="Button.add-tab-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.add-tab-button:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Style>
    </UserControl.Styles>

    <!-- ОСНОВНОЙ LAYOUT -->
    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Кнопка "+" (фиксированная слева) -->
            <ColumnDefinition Width="Auto"/>
            <!-- Область вкладок (прокручиваемая) -->
            <ColumnDefinition Width="*"/>
            <!-- Левая стрелка -->
            <ColumnDefinition Width="Auto"/>
            <!-- Правая стрелка -->
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- КНОПКА "+" -->
        <Button Grid.Column="0"
                Classes="add-tab-button"
                Command="{Binding AddTabCommand}"
                Width="36" Height="32"
                ToolTip.Tip="Новая вкладка">
            <Path Data="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  Width="14" Height="14"
                  Stretch="Uniform"/>
        </Button>

        <!-- ОБЛАСТЬ ВКЛАДОК -->
        <ScrollViewer Grid.Column="1"
                      x:Name="TabsScrollViewer"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      Background="Transparent"
                      Padding="4,0">
            <StackPanel x:Name="TabsPanel"
                        Orientation="Horizontal"
                        Spacing="2"
                        VerticalAlignment="Center"/>
        </ScrollViewer>

        <!-- ЛЕВАЯ СТРЕЛКА -->
        <Button Grid.Column="2"
                Classes="scroll-button"
                Command="{Binding ScrollLeftCommand}"
                IsVisible="{Binding CanScrollLeft}"
                Width="24" Height="32"
                ToolTip.Tip="Прокрутить влево">
            <Path Data="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  Width="12" Height="12"
                  Stretch="Uniform"/>
        </Button>

        <!-- ПРАВАЯ СТРЕЛКА -->
        <Button Grid.Column="3"
                Classes="scroll-button"
                Command="{Binding ScrollRightCommand}"
                IsVisible="{Binding CanScrollRight}"
                Width="24" Height="32"
                ToolTip.Tip="Прокрутить вправо">
            <Path Data="M8.59 16.59L10 18l6-6-6-6-1.41 1.41L13.17 12z"
                  Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                  Width="12" Height="12"
                  Stretch="Uniform"/>
        </Button>
    </Grid>
</UserControl>

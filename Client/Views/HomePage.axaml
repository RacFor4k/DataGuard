<!--
    HomePage - Стартовая (домашняя) страница приложения.
    Отображает приветствие и подсказку для выбора пункта меню.
-->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Client.Views.HomePage">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                Spacing="12">
        <TextBlock Text="Добро пожаловать в DataGuard"
                   FontSize="28"
                   HorizontalAlignment="Center"
                   FontWeight="SemiBold"/>
        <TextBlock Text="Выберите пункт в меню слева для начала работы"
                   FontSize="14"
                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                   HorizontalAlignment="Center"/>
    </StackPanel>
</UserControl>

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=dataguard;Username=postgres;Password=postgres;",
    "RedisConnection": "localhost:6379,password=password"
  },
  "Jwt": {
    "Key": "JWT_KEY",
    "Issuer": "DataGuard.Server",
    "Audience": "DataGuard.Server",
    "AccessTokenExpiration": "hhh:mm:ss",
    "RefreshTokenExpiration": "hhh:mm:ss"
  },
  "CompanyManager": {
    "MasterKeyHash": "MASTER_KEY_HASH"
  },
  "Security": {
    "NonceSecretKey": "NONCE_SECRET_KEY_Base64",
    "SaltLength": 32,
    "PasswordHashLength": 32,
    "EncryptedPasswordLength": 64,
    "EncryptedKeyLength": 32,
    "NonceLength": 12,
    "TagLength": 16,
    "MasterKeySalt": "MASTER_KEY_SALT_Base64",
    "Argon2": {
      "DegreeOfParallelism": 1,
      "Iterations": 3,
      "MemorySize": 19456,
      "HashLength": 32
    },
    "RsaKeySize": 4096
  }
}

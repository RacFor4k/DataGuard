<!-- Корневое представление раздела аудита, связывающее экран с моделью AuditViewModel. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.Manager.ViewModels"
             x:Class="Client.Manager.Views.AuditView"
             x:DataType="vm:AuditViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450">
  <!-- Основная тёмная область раздела аудита с отступами для будущего журнала событий. -->
  <Border Background="{DynamicResource AppBackgroundBrush}" Padding="28">
    <!-- Вертикальная панель, группирующая заголовок и пояснение раздела аудита. -->
    <StackPanel Spacing="8">
      <!-- Заголовок раздела аудита, показывающий назначение текущего экрана. -->
      <TextBlock Text="Аудит"
                 Foreground="{DynamicResource PrimaryTextBrush}"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <!-- Описание плейсхолдера для будущего журнала событий и фильтров аудита. -->
      <TextBlock Text="Плейсхолдер журнала событий и фильтров аудита."
                 Foreground="{DynamicResource SecondaryTextBrush}"
                 FontSize="14" />
    </StackPanel>
  </Border>
</UserControl>
<!-- Корневое представление раздела настроек, связывающее экран с моделью SettingsViewModel. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.Manager.ViewModels"
             x:Class="Client.Manager.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450">
  <!-- Основная тёмная область раздела настроек с отступами для будущих параметров приложения. -->
  <Border Background="{DynamicResource AppBackgroundBrush}" Padding="28">
    <!-- Вертикальная панель, группирующая заголовок и пояснение раздела настроек. -->
    <StackPanel Spacing="8">
      <!-- Заголовок раздела настроек, показывающий назначение текущего экрана. -->
      <TextBlock Text="Настройки"
                 Foreground="{DynamicResource PrimaryTextBrush}"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <!-- Описание плейсхолдера для будущих настроек приложения DataGuard Manager. -->
      <TextBlock Text="Плейсхолдер настроек приложения DataGuard Manager."
                 Foreground="{DynamicResource SecondaryTextBrush}"
                 FontSize="14" />
    </StackPanel>
  </Border>
</UserControl>
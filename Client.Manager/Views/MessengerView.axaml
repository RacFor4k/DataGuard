<!-- Корневой элемент пользовательского представления. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.Manager.ViewModels"
             x:Class="Client.Manager.Views.MessengerView"
             x:DataType="vm:MessengerViewModel"
             mc:Ignorable="d"
             d:DesignWidth="1000"
             d:DesignHeight="640">

  <!-- Основная сетка мессенджера со списком чатов и областью переписки. -->
  <Grid ColumnDefinitions="280,*" Background="{DynamicResource AppBackgroundBrush}">
    <!-- Левая панель навигации по чатам. -->
    <Border Grid.Column="0"
            Background="{DynamicResource PanelBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <!-- Сетка заголовка, поиска и списка диалогов. -->
      <Grid RowDefinitions="Auto,Auto,*">
        <!-- Верхний блок левой панели с заголовком и папками чатов. -->
        <Border Grid.Row="0" Padding="16,14" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0">
          <!-- Вертикальная группа заголовка чата и фильтров папок. -->
          <StackPanel Spacing="10">
            <!-- Заголовок раздела чатов. -->
            <TextBlock Text="Чат"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <!-- Список папок чатов. -->
            <ItemsControl ItemsSource="{Binding Folders}">
              <!-- Панель расположения элементов списка. -->
              <ItemsControl.ItemsPanel>
                <!-- Шаблон панели для коллекции элементов. -->
                <ItemsPanelTemplate>
                  <!-- Горизонтальная панель кнопок папок чатов. -->
                  <StackPanel Orientation="Horizontal" Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <!-- Шаблон отдельного элемента списка. -->
              <ItemsControl.ItemTemplate>
                <!-- Шаблон кнопки папки чатов. -->
                <DataTemplate DataType="vm:ChatFolderPlaceholder">
                  <!-- Кнопка выбора папки чатов. -->
                  <Button Classes.ChatFolderButton="True"
                          Classes.active="{Binding IsSelected}"
                          Command="{Binding $parent[UserControl].DataContext.SelectFolderCommand}"
                          CommandParameter="{Binding}"
                          ToolTip.Tip="Показать чаты папки">
                    <!-- Сетка названия папки и бейджа количества. -->
                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="6">
                      <!-- Название папки чатов. -->
                      <TextBlock Text="{Binding Name}" />
                      <!-- Бейдж папки с количеством видимых элементов. -->
                      <Border Grid.Column="1"
                              MinWidth="18"
                              Height="18"
                              Padding="4,0"
                              Background="{DynamicResource DangerBrush}"
                              CornerRadius="9"
                              IsVisible="{Binding HasVisibleBadge}">
                        <!-- Текст бейджа папки чатов. -->
                        <TextBlock Text="{Binding BadgeText}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                    </Grid>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <!-- Блок визуального поиска по чатам. -->
        <Border Grid.Row="1" Padding="12,0,12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,0">
          <!-- Визуальное поле поиска чатов. -->
          <Border Height="30" Background="{DynamicResource PanelSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6">
            <!-- Подсказка поля поиска чатов. -->
            <TextBlock Text="Поиск"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       VerticalAlignment="Center"
                       Margin="10,0" />
          </Border>
        </Border>

        <!-- Список доступных диалогов. -->
        <ItemsControl Grid.Row="2"
                      Margin="8"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding Chats}">
          <!-- Шаблон отдельного элемента списка. -->
          <ItemsControl.ItemTemplate>
            <!-- Шаблон элемента диалога. -->
            <DataTemplate DataType="vm:ChatPlaceholder">
              <!-- Кнопка выбора диалога. -->
              <Button Classes.ChatItemButton="True"
                      HorizontalAlignment="Stretch"
                      Classes.selected="{Binding IsSelected}"
                      Command="{Binding $parent[UserControl].DataContext.SelectChatCommand}"
                      CommandParameter="{Binding}">
                <!-- Внутренний контейнер элемента диалога. -->
                <Border Padding="10" HorizontalAlignment="Stretch">
                  <!-- Сетка аватара, описания и метаданных диалога. -->
                  <Grid ColumnDefinitions="34,*,Auto">
                    <!-- Круглый контейнер аватара диалога. -->
                    <Border Width="30" Height="30" Background="{DynamicResource PanelSecondaryBrush}" CornerRadius="15">
                      <!-- Иконка аватара диалога. -->
                      <Image Width="16" Height="16" Source="avares://Client.Styles/Assets/user.svg" />
                    </Border>
                    <!-- Группа названия и предпросмотра последнего сообщения. -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                      <!-- Название диалога. -->
                      <TextBlock Text="{Binding Name}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" />
                      <!-- Предпросмотр последнего сообщения диалога. -->
                      <TextBlock Text="{Binding Preview}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                    </StackPanel>
                    <!-- Группа времени и бейджа непрочитанных сообщений. -->
                    <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                      <!-- Время последнего сообщения. -->
                      <TextBlock Text="{Binding Time}" Foreground="{DynamicResource SubtleTextBrush}" FontSize="11" HorizontalAlignment="Right" />
                      <!-- Бейдж количества непрочитанных сообщений. -->
                      <Border MinWidth="18" Height="18" Padding="4,0" Background="{DynamicResource DangerBrush}" CornerRadius="9" IsVisible="{Binding HasUnread}">
                        <!-- Текст бейджа непрочитанных сообщений. -->
                        <TextBlock Text="{Binding BadgeText}" Foreground="White" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Border>
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Border>

    <!-- Правая область выбранного чата. -->
    <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
      <!-- Заголовок выбранного чата. -->
      <Border Grid.Row="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
        <!-- Кнопка открытия карточки пользователя выбранного чата. -->
        <Button Classes.HeaderProfileButton="True" ToolTip.Tip="Открыть карточку пользователя">
          <!-- Сетка аватара и описания выбранного чата. -->
          <Grid ColumnDefinitions="42,*" Margin="16,12" HorizontalAlignment="Stretch">
            <!-- Круглый контейнер аватара выбранного чата. -->
            <Border Width="34" Height="34" Background="{DynamicResource AccentSoftBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="17">
              <!-- Иконка аватара выбранного чата. -->
              <Image Width="18" Height="18" Source="avares://Client.Styles/Assets/user.svg" />
            </Border>
            <!-- Группа названия и подзаголовка выбранного чата. -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
              <!-- Название выбранного чата. -->
              <TextBlock Text="{Binding SelectedChatName}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" />
              <!-- Подзаголовок выбранного чата. -->
              <TextBlock Text="{Binding SelectedChatSubtitle}" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
            </StackPanel>
          </Grid>
        </Button>
      </Border>

      <!-- Прокручиваемая область сообщений выбранного чата. -->
      <ScrollViewer Grid.Row="1" Padding="16">
        <!-- Вертикальная лента сообщений. -->
        <StackPanel Spacing="12">
          <!-- Входящее сообщение в переписке. -->
          <Border MaxWidth="520" Padding="12" HorizontalAlignment="Left" Background="{DynamicResource PanelSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <!-- Текст входящего сообщения. -->
            <TextBlock Text="Добрый день. Нужно согласовать внешний доступ к договору поставки."
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       TextWrapping="Wrap" />
          </Border>
          <!-- Исходящее сообщение в переписке. -->
          <Border MaxWidth="520" Padding="12" HorizontalAlignment="Right" Background="{DynamicResource AccentBrush}" CornerRadius="10">
            <!-- Текст исходящего сообщения. -->
            <TextBlock Text="Проверю права и срок действия ссылки."
                       Foreground="White"
                       TextWrapping="Wrap" />
          </Border>
          <!-- Входящее сообщение с действиями согласования. -->
          <Border MaxWidth="520" Padding="12" HorizontalAlignment="Left" Background="{DynamicResource PanelSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10">
            <!-- Группа текста сообщения и кнопок решения. -->
            <StackPanel Spacing="8">
              <!-- Текст предпросмотра выбранного чата. -->
              <TextBlock Text="{Binding SelectedChatPreview}" Foreground="{DynamicResource PrimaryTextBrush}" />
              <!-- Горизонтальная группа кнопок согласования. -->
              <StackPanel Orientation="Horizontal" Spacing="8">
                <!-- Кнопка одобрения запроса из сообщения. -->
                <Button Classes="ChatFolderButton" Content="Одобрить" />
                <!-- Кнопка отклонения запроса из сообщения. -->
                <Button Classes="ChatFolderButton" Content="Отклонить" />
              </StackPanel>
            </StackPanel>
          </Border>
        </StackPanel>
      </ScrollViewer>

      <!-- Нижняя панель ввода нового сообщения. -->
      <Border Grid.Row="2" Padding="16,12" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
        <!-- Сетка поля ввода и кнопки отправки. -->
        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
          <!-- Визуальное поле ввода сообщения с кнопкой вложения. -->
          <Border Height="38" Background="{DynamicResource PanelSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8">
            <!-- Сетка кнопки вложения и текстовой подсказки. -->
            <Grid ColumnDefinitions="34,*">
              <!-- Кнопка прикрепления файла к сообщению. -->
              <Button Classes="ChatFolderButton" Padding="6" BorderThickness="0" Background="Transparent" ToolTip.Tip="Прикрепить файл">
                <!-- Иконка прикрепления файла. -->
                <Image Source="avares://Client.Styles/Assets/attach.svg" />
              </Button>
              <!-- Подсказка поля ввода сообщения. -->
              <TextBlock Grid.Column="1" Text="Напишите сообщение..."
                       Foreground="{DynamicResource SubtleTextBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0" />
            </Grid>
          </Border>
          <!-- Кнопка отправки сообщения. -->
          <Button Grid.Column="1" Classes="ChatFolderButton" Width="38" Padding="6" ToolTip.Tip="Отправить сообщение">
            <!-- Иконка отправки сообщения. -->
            <Image Source="avares://Client.Styles/Assets/send.svg" />
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</UserControl>

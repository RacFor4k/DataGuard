<!-- Корневое представление раздела внешнего доступа, связывающее экран с моделью ExternalAccessViewModel. -->
<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Client.Manager.ViewModels"
             x:Class="Client.Manager.Views.ExternalAccessView"
             x:DataType="vm:ExternalAccessViewModel"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450">
  <!-- Основная тёмная область раздела внешнего доступа с отступами для будущих разрешений. -->
  <Border Background="{DynamicResource AppBackgroundBrush}" Padding="28">
    <!-- Вертикальная панель, группирующая заголовок и пояснение раздела внешнего доступа. -->
    <StackPanel Spacing="8">
      <!-- Заголовок раздела внешнего доступа, показывающий назначение текущего экрана. -->
      <TextBlock Text="Внешний доступ"
                 Foreground="{DynamicResource PrimaryTextBrush}"
                 FontSize="24"
                 FontWeight="SemiBold" />
      <!-- Описание плейсхолдера для будущего управления внешними ссылками и доступами. -->
      <TextBlock Text="Плейсхолдер функций управления внешними ссылками и доступами."
                 Foreground="{DynamicResource SecondaryTextBrush}"
                 FontSize="14" />
    </StackPanel>
  </Border>
</UserControl>
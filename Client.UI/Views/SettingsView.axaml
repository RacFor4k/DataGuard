<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.UI.ViewModels"
             x:Class="Client.UI.Views.SettingsView"
             x:DataType="vm:SettingsViewModel"
             Background="#0F1117">

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="24,20"
                BorderBrush="#2D3748" BorderThickness="0,0,0,1" Background="#161B27">
            <TextBlock Text="Настройки" Classes="h2"/>
        </Border>

        <ScrollViewer HorizontalAlignment="Center" MaxWidth="640" Padding="24,24">
            <StackPanel Spacing="24">
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Подключение" Classes="h3"/>
                        <Rectangle Classes="divider"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Адрес сервера" Classes="muted"/>
                            <TextBox Text="{Binding ServerAddress}" Watermark="https://localhost:7777"/>
                        </StackPanel>
                        <Border Classes="badge-green" HorizontalAlignment="Left">
                            <TextBlock Text="● Подключено" FontSize="12" Foreground="#86EFAC"/>
                        </Border>
                        <Button Classes="secondary" Content="Проверить соединение" FontSize="13" Padding="14,8"/>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Безопасность" Classes="h3"/>
                        <Rectangle Classes="divider"/>
                        <CheckBox Content="Автоматически блокировать сессию" IsChecked="{Binding AutoLock}"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Длительность сессии (часов)" Classes="muted"/>
                            <TextBox Text="{Binding SessionHours}" Width="80" HorizontalAlignment="Left"/>
                        </StackPanel>
                        <Button Classes="secondary" Content="Сменить пароль" FontSize="13" Padding="14,8"/>
                    </StackPanel>
                </Border>

                <Border Classes="card" Background="#0D1120">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🛡️" FontSize="24"/>
                            <StackPanel Spacing="2">
                                <TextBlock Text="DataGuard" Classes="h3"/>
                                <TextBlock Text="Beta 1.1 · GUI Client" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                        <Rectangle Classes="divider"/>
                        <TextBlock Text=".NET 9 + Avalonia 11.2 + gRPC" Classes="muted" FontSize="12"/>
                    </StackPanel>
                </Border>

                <Grid ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0" IsVisible="{Binding SavedOk}" Background="#14532D"
                            CornerRadius="8" Padding="14,10" Margin="0,0,12,0">
                        <TextBlock Text="Настройки сохранены" Foreground="#86EFAC" FontSize="13"/>
                    </Border>
                    <Button Grid.Column="1" Classes="primary" Content="Сохранить"
                            Command="{Binding SaveCommand}" Height="44" Padding="20,0"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</UserControl>

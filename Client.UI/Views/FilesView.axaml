<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.UI.ViewModels"
             xmlns:models="using:Client.UI.Models"
             x:Class="Client.UI.Views.FilesView"
             x:DataType="vm:FilesViewModel"
             Background="#0F1117">

    <Grid ColumnDefinitions="260,*,Auto">

        <!-- LEFT: Folder tree -->
        <Border Grid.Column="0" Background="#161B27"
                BorderBrush="#2D3748" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="12,10"
                        BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Файлы" Classes="h3"/>
                        <TextBox Watermark="Поиск..." Text="{Binding SearchText}" Height="34" FontSize="12"/>
                        <Grid ColumnDefinitions="*,36">
                            <Button Grid.Column="0" Classes="primary" Content="+ Загрузить"
                                    Height="32" HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center" FontSize="12" Margin="0,0,6,0"/>
                            <Button Grid.Column="1" Classes="secondary" Content="📁"
                                    Height="32" HorizontalContentAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
                <ScrollViewer Padding="8,8">
                    <ItemsControl ItemsSource="{Binding FolderTree}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:FileItem">
                                <Button Classes="nav-btn" Margin="0,1">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Icon}" FontSize="14"/>
                                        <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- CENTER: File list -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Background="#161B27" Padding="16,10"
                    BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <TextBlock Text="📁" FontSize="14"/>
                        <TextBlock Text="{Binding CurrentPath}" FontSize="13" Foreground="#94A3B8"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                        <Button Classes="secondary" Content="Тип" FontSize="12" Padding="10,6"/>
                        <Button Classes="secondary" Content="Автор" FontSize="12" Padding="10,6"/>
                        <Button Classes="secondary" Content="Дата" FontSize="12" Padding="10,6"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Table header -->
            <Border DockPanel.Dock="Top" Padding="16,8"
                    BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,80,120,100,130">
                    <TextBlock Grid.Column="0" Text="Название" Classes="muted" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Размер" Classes="muted" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Владелец" Classes="muted" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Изменён" Classes="muted" FontSize="11" FontWeight="Bold"/>
                    <TextBlock Grid.Column="4" Text="Доступ" Classes="muted" FontSize="11" FontWeight="Bold"/>
                </Grid>
            </Border>

            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding FilteredFiles}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:FileItem">
                            <Button Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                    Padding="16,0" Cursor="Hand"
                                    Command="{Binding $parent[UserControl].((vm:FilesViewModel)DataContext).SelectFileCommand}"
                                    CommandParameter="{Binding}">
                                <Button.Styles>
                                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#1E2535"/>
                                    </Style>
                                </Button.Styles>
                                <Grid ColumnDefinitions="*,80,120,100,130" Margin="0,10">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="{Binding Icon}" FontSize="16"/>
                                        <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#F1F5F9" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Size}" Classes="muted" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Owner}" Classes="muted" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Modified}" Classes="muted" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Access}" FontSize="11" Foreground="#94A3B8" VerticalAlignment="Center"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>

        <!-- RIGHT: Context panel -->
        <Border Grid.Column="2" Width="300" Background="#161B27"
                BorderBrush="#2D3748" BorderThickness="1,0,0,0"
                IsVisible="{Binding ShowRightPanel}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,12"
                        BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Свойства файла" Classes="h3" VerticalAlignment="Center"
                                   IsVisible="{Binding ShowPropertiesPanel}"/>
                        <TextBlock Grid.Column="0" Text="Создать ссылку" Classes="h3" VerticalAlignment="Center"
                                   IsVisible="{Binding ShowSharePanel}"/>
                        <Button Grid.Column="1" Classes="ghost" Content="✕" Width="28" Height="28"
                                HorizontalContentAlignment="Center" Command="{Binding ClosePanelCommand}"/>
                    </Grid>
                </Border>

                <ScrollViewer Padding="16">
                  <Panel>
                    <!-- PROPERTIES -->
                    <StackPanel IsVisible="{Binding ShowPropertiesPanel}" Spacing="16">
                        <StackPanel HorizontalAlignment="Center" Spacing="8">
                            <TextBlock Text="{Binding SelectedFile.Icon}" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding SelectedFile.Name}" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#F1F5F9" HorizontalAlignment="Center"
                                       TextWrapping="Wrap" TextAlignment="Center"/>
                        </StackPanel>
                        <Rectangle Classes="divider"/>
                        <StackPanel Spacing="10">
                            <Grid ColumnDefinitions="90,*">
                                <TextBlock Grid.Column="0" Text="Размер" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFile.Size}" FontSize="12" Foreground="#F1F5F9"/>
                            </Grid>
                            <Grid ColumnDefinitions="90,*">
                                <TextBlock Grid.Column="0" Text="Владелец" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFile.Owner}" FontSize="12" Foreground="#F1F5F9"/>
                            </Grid>
                            <Grid ColumnDefinitions="90,*">
                                <TextBlock Grid.Column="0" Text="Изменён" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFile.Modified}" FontSize="12" Foreground="#F1F5F9"/>
                            </Grid>
                            <Grid ColumnDefinitions="90,*">
                                <TextBlock Grid.Column="0" Text="Доступ" Classes="muted" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="{Binding SelectedFile.Access}" FontSize="12" Foreground="#86EFAC"/>
                            </Grid>
                        </StackPanel>
                        <Rectangle Classes="divider"/>
                        <StackPanel Spacing="8">
                            <Button Classes="primary" Content="🔗 Поделиться"
                                    Command="{Binding OpenShareCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Classes="secondary" Content="💬 Чат по документу"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            <Button Classes="secondary" Content="⏱ История действий"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- SHARE PANEL -->
                    <StackPanel IsVisible="{Binding ShowSharePanel}" Spacing="14">
                        <Button Classes="ghost" Content="← Назад"
                                Command="{Binding BackToPropertiesCommand}"
                                Foreground="#64748B" FontSize="12" Padding="0"/>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Тип ссылки" Classes="muted" FontSize="12"/>
                            <ComboBox SelectedIndex="1" HorizontalAlignment="Stretch">
                                <ComboBoxItem>Внутренняя</ComboBoxItem>
                                <ComboBoxItem>Гостевая</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Срок действия" Classes="muted" FontSize="12"/>
                            <ComboBox SelectedIndex="1" HorizontalAlignment="Stretch">
                                <ComboBoxItem>1 час</ComboBoxItem>
                                <ComboBoxItem>24 часа</ComboBoxItem>
                                <ComboBoxItem>7 дней</ComboBoxItem>
                                <ComboBoxItem>30 дней</ComboBoxItem>
                                <ComboBoxItem>Самоуничтожение</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Spacing="8">
                            <TextBlock Text="Права" Classes="muted" FontSize="12"/>
                            <CheckBox Content="Разрешить скачивание" IsChecked="{Binding AllowDownload}" FontSize="13"/>
                            <CheckBox Content="Водяной знак" IsChecked="{Binding Watermark}" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Часы доступа" Classes="muted" FontSize="12"/>
                            <Grid ColumnDefinitions="*,16,*">
                                <TextBox Grid.Column="0" Watermark="10:00" FontSize="12"/>
                                <TextBlock Grid.Column="1" Text="—" Foreground="#64748B"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBox Grid.Column="2" Watermark="18:00" FontSize="12"/>
                            </Grid>
                        </StackPanel>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Лимит попыток" Classes="muted" FontSize="12"/>
                            <TextBox Watermark="Без ограничений" FontSize="12"/>
                        </StackPanel>
                        <Button Classes="primary" Content="⚡ Сгенерировать ссылку"
                                Command="{Binding GenerateLinkCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="40"/>
                        <StackPanel IsVisible="{Binding LinkGenerated}" Spacing="8">
                            <Rectangle Classes="divider"/>
                            <TextBlock Text="Ссылка создана:" Classes="muted" FontSize="12"/>
                            <Border Classes="card-sm" Background="#0F1117">
                                <TextBlock Text="{Binding GeneratedLink}" FontSize="11"
                                           Foreground="#3B82F6" TextWrapping="Wrap"/>
                            </Border>
                            <Button Classes="secondary" Content="📋 Копировать"
                                    Command="{Binding CopyLinkCommand}"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                  </Panel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

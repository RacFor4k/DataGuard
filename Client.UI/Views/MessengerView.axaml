<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Client.UI.ViewModels"
             xmlns:models="using:Client.UI.Models"
             x:Class="Client.UI.Views.MessengerView"
             x:DataType="vm:MessengerViewModel"
             Background="#0F1117">

    <Grid ColumnDefinitions="280,*">
        <!-- Thread list -->
        <Border Grid.Column="0" Background="#161B27" BorderBrush="#2D3748" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="16,14" BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                    <TextBlock Text="Мессенджер" Classes="h3"/>
                </Border>
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Threads}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ChatThread">
                                <Button Background="Transparent" BorderThickness="0"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                        Padding="12,10" Cursor="Hand"
                                        Command="{Binding $parent[UserControl].((vm:MessengerViewModel)DataContext).SelectThreadCommand}"
                                        CommandParameter="{Binding}">
                                    <Button.Styles>
                                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                                            <Setter Property="Background" Value="#1E2535"/>
                                        </Style>
                                    </Button.Styles>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Width="38" Height="38" CornerRadius="19"
                                                Background="#1E2535" Margin="0,0,10,0">
                                            <TextBlock Text="{Binding Icon}" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" Spacing="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#F1F5F9" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding LastMessage}" FontSize="12"
                                                       Foreground="#64748B" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding Time}" FontSize="11" Foreground="#475569"/>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Chat area -->
        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto"
              IsVisible="{Binding SelectedThread, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Border Grid.Row="0" Background="#161B27" Padding="16,12"
                    BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="{Binding SelectedThread.Icon}" FontSize="18" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedThread.Name}" Classes="h3"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                IsVisible="{Binding SelectedThread.IsDocument}">
                        <Button Classes="success" Content="✅ Одобрить"
                                Command="{Binding ApproveAccessCommand}" FontSize="12"/>
                        <Button Classes="danger" Content="✕ Отклонить"
                                Command="{Binding DenyAccessCommand}" FontSize="12"/>
                        <Button Classes="secondary" Content="📄 К файлу" FontSize="12"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" Padding="20,16">
                <ItemsControl ItemsSource="{Binding SelectedThread.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ChatMessage">
                            <StackPanel Margin="0,6">
                                <Border IsVisible="{Binding IsSystem}"
                                        HorizontalAlignment="Center" Margin="0,4"
                                        Background="#1E2535" CornerRadius="12" Padding="12,5">
                                    <TextBlock Text="{Binding Content}" FontSize="12" Foreground="#64748B"/>
                                </Border>
                                <StackPanel IsVisible="{Binding !IsSystem}">
                                    <TextBlock Text="{Binding Author}" FontSize="11" Foreground="#475569"
                                               Margin="8,0,0,3" IsVisible="{Binding !IsMe}"/>
                                    <Border CornerRadius="12" MaxWidth="400" Padding="12,8"
                                            Background="#1E2535" HorizontalAlignment="Left">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Content}" FontSize="13"
                                                       Foreground="#F1F5F9" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Time}" FontSize="10"
                                                       Foreground="#475569" HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Border Grid.Row="2" Padding="16,12" Background="#161B27"
                    BorderBrush="#2D3748" BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Watermark="Напишите сообщение..."
                             Text="{Binding MessageInput}" Height="40" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Classes="primary" Content="Отправить"
                            Command="{Binding SendMessageCommand}" Height="40"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

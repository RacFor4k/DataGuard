<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DataGuard.UI.ViewModels"
             xmlns:models="using:DataGuard.UI.Models"
             x:Class="DataGuard.UI.Views.ExternalAccessView"
             x:DataType="vm:ExternalAccessViewModel"
             Background="#0F1117">

    <Grid ColumnDefinitions="*,Auto">
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Padding="24,20"
                    BorderBrush="#2D3748" BorderThickness="0,0,0,1" Background="#161B27">
                <StackPanel Spacing="16">
                    <TextBlock Text="Внешний доступ" Classes="h2"/>
                    <Grid ColumnDefinitions="*,*,*,*">
                        <Border Grid.Column="0" Classes="kpi-card" Margin="0,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding ActiveContractors}" FontSize="28" FontWeight="Bold" Foreground="#3B82F6"/>
                                <TextBlock Text="Активных контрагентов" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Classes="kpi-card" Margin="0,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding OpenSessions}" FontSize="28" FontWeight="Bold" Foreground="#22C55E"/>
                                <TextBlock Text="Открытых сессий" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Classes="kpi-card" Margin="0,0,8,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding TotalTransferred}" FontSize="28" FontWeight="Bold" Foreground="#F1F5F9"/>
                                <TextBlock Text="Передано файлов" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Classes="kpi-card" Background="#1A0A0A" BorderBrush="#7F1D1D">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{Binding Warnings}" FontSize="28" FontWeight="Bold" Foreground="#EF4444"/>
                                <TextBlock Text="Предупреждений" Classes="muted" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer Padding="24,20">
                <StackPanel Spacing="24">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Активные ссылки" Classes="h3"/>
                            <Button Grid.Column="1" Classes="primary" Content="+ Создать ссылку" FontSize="12" Padding="12,6"/>
                        </Grid>

                        <Border Background="#161B27" CornerRadius="8,8,0,0"
                                BorderBrush="#2D3748" BorderThickness="1,1,1,0" Padding="14,8">
                            <Grid ColumnDefinitions="*,120,110,110,80,90">
                                <TextBlock Grid.Column="0" Text="Файл" Classes="muted" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="Контрагент" Classes="muted" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="2" Text="Истекает" Classes="muted" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="3" Text="Права" Classes="muted" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="4" Text="Загрузок" Classes="muted" FontSize="11" FontWeight="Bold"/>
                                <TextBlock Grid.Column="5" Text="Статус" Classes="muted" FontSize="11" FontWeight="Bold"/>
                            </Grid>
                        </Border>
                        <Border BorderBrush="#2D3748" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                            <ItemsControl ItemsSource="{Binding Links}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:ExternalLink">
                                        <Button Background="Transparent" BorderThickness="0"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                Padding="14,10" Cursor="Hand"
                                                Command="{Binding $parent[UserControl].((vm:ExternalAccessViewModel)DataContext).SelectLinkCommand}"
                                                CommandParameter="{Binding}">
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="#1E2535"/>
                                                </Style>
                                            </Button.Styles>
                                            <Grid ColumnDefinitions="*,120,110,110,80,90">
                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="📄" FontSize="14"/>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" Foreground="#F1F5F9"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Target}" Classes="muted" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Grid.Column="2" Text="{Binding Expires}" Classes="muted" FontSize="12" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="{Binding Permissions}" Classes="muted" FontSize="11" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4" FontSize="12" VerticalAlignment="Center" Foreground="#94A3B8">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0}/{1}">
                                                            <Binding Path="Downloads"/>
                                                            <Binding Path="MaxDownloads"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                                <Border Grid.Column="5" Classes="badge-green" VerticalAlignment="Center" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#86EFAC"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>

                    <!-- Journal -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Журнал внешних действий" Classes="h3"/>
                        <Border Classes="card" Padding="0" Background="#161B27">
                            <ItemsControl ItemsSource="{Binding Journal}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:AuditEntry">
                                        <Border Padding="16,10" BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="60,*,80">
                                                <TextBlock Grid.Column="0" Text="{Binding Time}" Classes="muted" FontSize="12" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="{Binding Target}" FontSize="13" Foreground="#F1F5F9"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="{Binding User}" Classes="muted" FontSize="11"/>
                                                        <TextBlock Text="·" Classes="muted" FontSize="11"/>
                                                        <TextBlock Text="{Binding Action}" Classes="muted" FontSize="11"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{Binding Result}" FontSize="12" Foreground="#86EFAC" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>

        <!-- Detail panel -->
        <Border Grid.Column="1" Width="280" Background="#161B27"
                BorderBrush="#2D3748" BorderThickness="1,0,0,0"
                IsVisible="{Binding ShowDetail}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="14,12"
                        BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock Grid.Column="0" Text="Детали ссылки" Classes="h3" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Classes="ghost" Content="✕" Width="28" Height="28"
                                HorizontalContentAlignment="Center" Command="{Binding CloseDetailCommand}"/>
                    </Grid>
                </Border>
                <ScrollViewer Padding="14">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding SelectedLink.Name}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#F1F5F9" TextWrapping="Wrap"/>
                        <Border Classes="badge-blue" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding SelectedLink.Status}" FontSize="11" Foreground="#93C5FD"/>
                        </Border>
                        <Rectangle Classes="divider"/>
                        <Grid ColumnDefinitions="85,*">
                            <TextBlock Grid.Column="0" Text="Контрагент" Classes="muted" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedLink.Target}" FontSize="12" Foreground="#F1F5F9" TextWrapping="Wrap"/>
                        </Grid>
                        <Grid ColumnDefinitions="85,*">
                            <TextBlock Grid.Column="0" Text="Истекает" Classes="muted" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedLink.Expires}" FontSize="12" Foreground="#F1F5F9"/>
                        </Grid>
                        <Grid ColumnDefinitions="85,*">
                            <TextBlock Grid.Column="0" Text="Права" Classes="muted" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedLink.Permissions}" FontSize="12" Foreground="#F1F5F9"/>
                        </Grid>
                        <Grid ColumnDefinitions="85,*">
                            <TextBlock Grid.Column="0" Text="Создал" Classes="muted" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="{Binding SelectedLink.CreatedBy}" FontSize="12" Foreground="#F1F5F9"/>
                        </Grid>
                        <Rectangle Classes="divider"/>
                        <Button Classes="secondary" Content="🕐 Продлить" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Classes="secondary" Content="✏ Изменить" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                        <Button Classes="danger" Content="⊗ Отозвать" Command="{Binding RevokeLinkCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

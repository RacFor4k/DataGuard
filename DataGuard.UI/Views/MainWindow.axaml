<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DataGuard.UI.ViewModels"
        xmlns:views="using:DataGuard.UI.Views"
        x:Class="DataGuard.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="DataGuard"
        Width="1280" Height="800"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid RowDefinitions="Auto,*">

        <!-- Title Bar -->
        <Grid Grid.Row="0" Height="38" Background="#0F1117" IsVisible="{Binding IsAuthenticated}">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="🛡" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="DataGuard" FontSize="13" FontWeight="SemiBold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                    <TextBlock Text=" — " Foreground="#475569" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentCompanyName}" FontSize="13" Foreground="#64748B" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="ghost" Content="—" Width="46" Height="38" HorizontalContentAlignment="Center" Command="{Binding MinimizeCommand}"/>
                    <Button Classes="ghost" Content="⊡" Width="46" Height="38" HorizontalContentAlignment="Center" Command="{Binding MaximizeCommand}"/>
                    <Button Content="✕" Width="46" Height="38" HorizontalContentAlignment="Center"
                            Background="Transparent" Foreground="#94A3B8" BorderThickness="0" Cursor="Hand"
                            Command="{Binding CloseCommand}">
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#C0392B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="1">

            <!-- AUTH -->
            <Panel IsVisible="{Binding ShowLogin}">
                <views:LoginView DataContext="{Binding LoginVM}"/>
            </Panel>
            <Panel IsVisible="{Binding ShowRegister}">
                <views:RegisterView DataContext="{Binding RegisterVM}"/>
            </Panel>
            <Panel IsVisible="{Binding ShowSetup}">
                <views:SetupCompanyView DataContext="{Binding SetupVM}"/>
            </Panel>

            <!-- MAIN SHELL -->
            <Grid IsVisible="{Binding IsAuthenticated}" ColumnDefinitions="220,*">

                <!-- SIDEBAR -->
                <Border Grid.Column="0" Background="#161B27" BorderBrush="#2D3748" BorderThickness="0,0,1,0">
                    <Grid RowDefinitions="Auto,*,Auto">

                        <Border Grid.Row="0" Padding="16,20,16,16" BorderBrush="#2D3748" BorderThickness="0,0,0,1">
                            <StackPanel Spacing="2">
                                <TextBlock Text="DataGuard" Classes="h2" FontSize="16"/>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Border Classes="badge-green">
                                        <TextBlock Text="● Online" FontSize="10" Foreground="#86EFAC"/>
                                    </Border>
                                    <TextBlock Text="{Binding CurrentUserName}" Classes="muted" VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" Margin="8,12">
                            <StackPanel Spacing="2">
                                <TextBlock Text="РАБОЧЕЕ ПРОСТРАНСТВО" Classes="muted" Margin="12,0,0,8" FontSize="10" FontWeight="Bold"/>
                                <Button Classes="nav-btn" Command="{Binding NavigateCommand}" CommandParameter="Files">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="📁" FontSize="16"/>
                                        <TextBlock Text="Файлы" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="nav-btn" Command="{Binding NavigateCommand}" CommandParameter="Messenger">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="💬" FontSize="16"/>
                                        <TextBlock Text="Мессенджер" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="БЕЗОПАСНОСТЬ" Classes="muted" Margin="12,12,0,8" FontSize="10" FontWeight="Bold"/>
                                <Button Classes="nav-btn" Command="{Binding NavigateCommand}" CommandParameter="ExternalAccess">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="🔗" FontSize="16"/>
                                        <TextBlock Text="Внешний доступ" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="nav-btn" Command="{Binding NavigateCommand}" CommandParameter="Policies">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="🛡" FontSize="16"/>
                                        <TextBlock Text="Политики" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Classes="nav-btn" Command="{Binding NavigateCommand}" CommandParameter="Audit">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="📊" FontSize="16"/>
                                        <TextBlock Text="Аудит" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="НАСТРОЙКИ" Classes="muted" Margin="12,12,0,8" FontSize="10" FontWeight="Bold"/>
                                <Button Classes="nav-btn" Command="{Binding NavigateCommand}" CommandParameter="Settings">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Text="⚙" FontSize="16"/>
                                        <TextBlock Text="Настройки" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Padding="16,12" BorderBrush="#2D3748" BorderThickness="0,1,0,0">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Хранилище" Classes="muted"/>
                                    <TextBlock Grid.Column="1" Classes="muted" Text="{Binding StorageUsed}"/>
                                </Grid>
                                <ProgressBar Value="{Binding StoragePercent}" Maximum="100" Height="4"
                                             CornerRadius="2" Background="#2D3748" Foreground="#3B82F6"/>
                                <Button Classes="ghost" HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding LogoutCommand}" Padding="0,6">
                                    <TextBlock Text="Выйти" Foreground="#EF4444" FontSize="12"/>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- CONTENT -->
                <Grid Grid.Column="1">
                    <Panel IsVisible="{Binding ShowFiles}">
                        <views:FilesView DataContext="{Binding FilesVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding ShowMessenger}">
                        <views:MessengerView DataContext="{Binding MessengerVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding ShowExternalAccess}">
                        <views:ExternalAccessView DataContext="{Binding ExternalAccessVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding ShowPolicies}">
                        <views:PoliciesView DataContext="{Binding PoliciesVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding ShowAudit}">
                        <views:AuditView DataContext="{Binding AuditVM}"/>
                    </Panel>
                    <Panel IsVisible="{Binding ShowSettings}">
                        <views:SettingsView DataContext="{Binding SettingsVM}"/>
                    </Panel>
                </Grid>
            </Grid>
        </Grid>

        <!-- TOASTS -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding Notifications}"
                      HorizontalAlignment="Right" VerticalAlignment="Bottom"
                      Margin="0,0,16,16" IsHitTestVisible="False">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Classes="toast" Margin="0,6,0,0">
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="18"
                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#F1F5F9"/>
                                <TextBlock Text="{Binding Message}" FontSize="12" Foreground="#94A3B8" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

    </Grid>
</Window>

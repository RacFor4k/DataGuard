<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DataGuard.UI.ViewModels"
             x:Class="DataGuard.UI.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#0F1117">
  <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="420">
    <StackPanel Spacing="0">
      <StackPanel HorizontalAlignment="Center" Spacing="10" Margin="0,0,0,36">
        <Border Width="64" Height="64" CornerRadius="18" Background="#0D1B3E"
                BorderBrush="#1E3A5F" BorderThickness="1" HorizontalAlignment="Center">
          <TextBlock Text="🛡️" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="DataGuard" FontSize="26" FontWeight="Bold"
                   Foreground="#F1F5F9" HorizontalAlignment="Center"/>
        <TextBlock Text="Защищённый корпоративный документооборот"
                   FontSize="13" Foreground="#475569" HorizontalAlignment="Center"/>
      </StackPanel>

      <Border Background="#0D1120" BorderBrush="#1E2535" BorderThickness="1"
              CornerRadius="14" Padding="32">
        <StackPanel Spacing="20">
          <TextBlock Text="Вход в систему" FontSize="16" FontWeight="SemiBold"
                     Foreground="#F1F5F9" HorizontalAlignment="Center"/>

          <Border IsVisible="{Binding HasError}" Background="#1A0808" BorderBrush="#7F1D1D"
                  BorderThickness="1" CornerRadius="8" Padding="14,10">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5"
                       FontSize="13" TextWrapping="Wrap"/>
          </Border>

          <StackPanel Spacing="6">
            <TextBlock Text="Пароль" Foreground="#64748B" FontSize="12" FontWeight="SemiBold"/>
            <TextBox Watermark="Введите пароль..." PasswordChar="●"
                     Text="{Binding Password}" Height="42" FontSize="14"/>
          </StackPanel>

          <Border Background="#0A0E1A" CornerRadius="8" Padding="12,8">
            <TextBlock FontSize="12" Foreground="#334155">
              Демо: введите пароль <Run Text="demo" FontFamily="Cascadia Code, Consolas, Monospace"
                                        Foreground="#3B82F6"/>
            </TextBlock>
          </Border>

          <Button Classes="primary" HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center" Height="44"
                  Command="{Binding LoginCommand}">
            <StackPanel Orientation="Horizontal" Spacing="8"
                        IsVisible="{Binding !IsLoading}">
              <TextBlock Text="Войти" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
          </Button>

          <StackPanel IsVisible="{Binding IsLoading}" Orientation="Horizontal"
                      HorizontalAlignment="Center" Spacing="8">
            <TextBlock Text="Подключение к серверу..." Foreground="#475569" FontSize="12"/>
          </StackPanel>

          <Rectangle Height="1" Fill="#1E2535"/>

          <Grid ColumnDefinitions="*,*">
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="0,8" Cursor="Hand" Command="{Binding NavigateToRegisterCommand}">
              <TextBlock Text="Регистрация" Foreground="#3B82F6" FontSize="13"/>
            </Button>
            <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Padding="0,8" Cursor="Hand" Command="{Binding NavigateToSetupCommand}">
              <TextBlock Text="Создать компанию" Foreground="#475569" FontSize="12"/>
            </Button>
          </Grid>
        </StackPanel>
      </Border>

      <TextBlock Text="DataGuard Beta 1.1 · © 2026" Foreground="#1E2535"
                 HorizontalAlignment="Center" Margin="0,16,0,0" FontSize="12"/>
    </StackPanel>
  </Grid>
</UserControl>

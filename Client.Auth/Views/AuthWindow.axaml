<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Client.Auth.ViewModels"
        xmlns:views="using:Client.Auth.Views"
        x:Class="Client.Auth.Views.AuthWindow"
        x:DataType="vm:AuthViewModel"
        Title="DataGuard — Вход"
        Width="480" Height="620"
        MinWidth="440" MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="#0F1117"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Title Bar -->
        <Border Grid.Row="0" Height="32" Background="#0F1117"
                PointerPressed="TitleBar_PointerPressed">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Path Data="{StaticResource IconShield}" Fill="#3B82F6"
                          Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="DataGuard" FontSize="12" FontWeight="SemiBold"
                               Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="titlebar-btn" Width="46" Height="32"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding MinimizeCommand}">
                        <Path Data="{StaticResource IconMinimize}" Fill="#94A3B8"
                              Width="10" Height="10"/>
                    </Button>
                    <Button Classes="titlebar-btn titlebar-close" Width="46" Height="32"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                            Command="{Binding CloseCommand}">
                        <Path Data="{StaticResource IconClose}" Fill="#94A3B8"
                              Width="10" Height="10"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Panel IsVisible="{Binding ShowLogin}">
                <views:LoginView DataContext="{Binding}"/>
            </Panel>
            <Panel IsVisible="{Binding ShowRegister}">
                <views:RegisterView DataContext="{Binding}"/>
            </Panel>
        </Grid>
    </Grid>
</Window>
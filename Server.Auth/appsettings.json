{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/server-auth-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "ConnectionStrings": {
    "PostgresConnection": "Host=localhost;Port=5432;Database=dataguard;Username=dataguard;Password=${DB_PASSWORD};",
    "RedisConnection": "localhost:6379,password=${REDIS_PASSWORD}"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "HttpStatusCode": 429,
    "GeneralRules": [
      { "Endpoint": "*", "Period": "1s", "Limit": 10 }
    ]
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "DataGuard.Server",
    "Audience": "DataGuard.Server",
    "AccessTokenExpiration": "00:30:00",
    "RefreshTokenExpiration": "1.00:00:00",
    "ClockSkew": "00:01:00"
  },
  "CompanyManager": {
    "MasterKeyHash": "${COMPANY_MANAGER_MASTER_KEY_HASH}"
  },
  "Security": {
    "NonceSecretKey": "${SECURITY_NONCE_SECRET_KEY}",
    "SaltLength": 32,
    "PasswordHashLength": 32,
    "EncryptedPasswordLength": 64,
    "EncryptedKeyLength": 32,
    "NonceLength": 12,
    "TagLength": 16,
    "MasterKeySalt": "${SECURITY_MASTER_KEY_SALT}",
    "Argon2": {
      "DegreeOfParallelism": 1,
      "Iterations": 3,
      "MemorySize": 19456,
      "HashLength": 32
    },
    "RsaKeySize": 4096
  }
}
